
generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider  = "postgresql"
}

enum UserTier{
  BASIC
  PRO
}

model User {
  id    String @id @default(cuid())
  name  String?
  email String @unique
  password String?
  emailVerified DateTime?
  image String?
  tier  UserTier @default(BASIC)
  subscriptionEnd  DateTime?
  accounts Account[]
  investments   Investment[]
  systemevent   SystemEvent[]
  transactions Transaction[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Transaction {
  id String @id @default(cuid())
  amount Float
  description String
  category String?
  date DateTime
  userId String
  user User @relation(fields:[userId],references:[id])
  @@index([userId, date])
  @@index([userId, category])
}

model Account {
  id String @id @default(cuid())
  userId String
  type String
  provider String
  providerAccountId String
  refresh_token String? 
  access_token String? 
  expires_at Int?
  token_type String?
  scope String?
  id_token String?
  session_state String?
  user User @relation(fields:[userId],references:[id])

  @@unique([provider, providerAccountId])
}

enum InvestmentType {
  EQUITY_STOCK
  SIP_MUTUAL_FUND
}

model Investment {
  id              String @id @default(cuid())
  userId          String
  symbol          String
  name            String
  type            InvestmentType
  sharesOwned     Float
  avgBuyPrice     Float
  sipAmount       Float?
  sipDay          Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade) 
  
  @@index([userId])

}

model SystemEvent {
  id             String    @id @default(cuid())
  userId         String
  title          String
  message        String 
  type           String
  read           Boolean  @default(false)
  createdAt      DateTime @default(now())
  
  user           User      @relation(fields:[userId],references:[id],onDelete: Cascade)
  @@index([userId, createdAt])
}


